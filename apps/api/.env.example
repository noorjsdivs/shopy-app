# Host port defaults to 5433 (see docker-compose.yml DB_PORT) to avoid clashing with a local Postgres on 5432.
DATABASE_URL="postgresql://shopy:shopy@localhost:5433/shopy?schema=public"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="30d"
PORT=4000
CORS_ORIGIN="*"
