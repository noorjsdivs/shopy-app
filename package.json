{
  "name": "shopy",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "api:dev": "npm run start:dev -w apps/api",
    "api:build": "npm run build -w apps/api",
    "api:migrate": "npm run prisma:migrate -w apps/api",
    "api:seed": "npm run prisma:seed -w apps/api",
    "api:studio": "npm run prisma:studio -w apps/api",
    "mobile:dev": "npm run start -w apps/mobile"
  },
  "engines": {
    "node": ">=20.19"
  }
}
